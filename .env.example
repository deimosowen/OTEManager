# Как использовать при `npm run dev`:
# 1) Скопируйте этот файл в корень проекта как `.env.local` (именно так — он в .gitignore и не уйдёт в Git).
# 2) Заполните ID/секрет Яндекса и при необходимости смените URL/секрет сессии.
# Nuxt подхватывает `.env`, `.env.local`, `.env.development` и т.д. из каталога, где лежит nuxt.config.js.

# Публичный URL приложения (без слэша в конце). Должен совпадать с «Redirect URI» в Яндекс OAuth.
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Приложение Яндекс OAuth: https://oauth.yandex.ru/ → создать приложение → Callback URL:
# {NUXT_PUBLIC_SITE_URL}/api/auth/yandex/callback
NUXT_PUBLIC_YANDEX_CLIENT_ID=
NUXT_YANDEX_CLIENT_SECRET=

# Случайная длинная строка для подписи cookie-сессии (например: openssl rand -hex 32)
NUXT_SESSION_SECRET=

# Необязательно: только указанные домены email (через запятую). Пусто = все домены.
# NUXT_ALLOWED_EMAIL_DOMAINS=company.ru,yandex.ru

# --- Yandex Cloud: список ВМ OTE (Compute) ---
# Каталог из консоли: .../folders/<FOLDER_ID>/compute/instances
# NUXT_YC_FOLDER_ID=b1gvjiodhunmecub9mct
#
# Ключ сервисного аккаунта (JSON) — один из вариантов:
# NUXT_YC_SA_KEY_PATH=keys/yc-sa.json
# либо одна строка (без переносов): NUXT_YC_SERVICE_ACCOUNT_JSON={"id":"...","service_account_id":"...",...}
#
# Отбор ВМ с меткой (по умолчанию как у инстансов OTE в консоли):
# NUXT_YC_INSTANCE_LABEL_KEY=metadata-tag
# NUXT_YC_INSTANCE_LABEL_VALUE=
# Несколько ВМ в одну строку списка — общая метка, например имя окружения:
# NUXT_YC_GROUP_BY_LABEL_KEY=ote-env
#
# Таблица на главной «как в TeamCity» (владелец → тег → ВМ):
# NUXT_YC_USERNAME_LABEL_KEYS=username,ldap-user,owner,login
# NUXT_YC_DELETE_DATE_LABEL_KEYS=delete-date,delete_date,delete-until,autodelete-date
# NUXT_YC_DELETE_DATE_META_KEYS=delete-date,delete_date,deleteDate,autodelete-date
# NUXT_YC_QUOTA_MAX_CPU=400
# NUXT_YC_QUOTA_MAX_MEMORY_GB=1000
#
# MVP-список (метки на ВМ): автор, версии, URL приложения
# NUXT_YC_OTE_AUTHOR_LABEL=run-by
# NUXT_YC_OTE_VERSION_BACKEND_LABELS=caseone-version,backend-version
# NUXT_YC_OTE_VERSION_FRONTEND_LABELS=frontend-version,ui-version
# NUXT_YC_OTE_APP_URL_LABELS=ote-url,app-url
# NUXT_YC_OTE_APP_URL_META_KEYS=app_url
# Публичный URL, если нет в метках: {slug} = metadata-tag или имя ВМ без -app/-everything
# NUXT_YC_OTE_APP_PUBLIC_URL_TEMPLATE=https://{slug}.caseone.devpravo.tech
# Внутренний FQDN YC (*.internal) — только если явно нужно:
# NUXT_YC_OTE_APP_HTTPS_FROM_FQDN=true
# Ссылка на внешний профиль: {user} или {login} из метки run-by
# NUXT_PUBLIC_PROFILE_URL_TEMPLATE=https://example.com/users/{user}
#
# Какие ключи реально есть у ВМ в каталоге: GET /api/ote/discover (после входа)
