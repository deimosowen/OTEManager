# Скопируйте в `.env.docker` и подставьте значения.
# Запуск: `docker compose --env-file .env.docker up -d` (или `env_file` в compose уже указывает на .env.docker — см. README).

# --- Обязательно для входа (Яндекс OAuth) ---
# Публичный URL, по которому открывают приложение (без / в конце). Должен совпадать с Redirect URI в кабинете Яндекса.
NUXT_PUBLIC_SITE_URL=https://ote.example.com
NUXT_PUBLIC_YANDEX_CLIENT_ID=
NUXT_YANDEX_CLIENT_SECRET=
# openssl rand -hex 32
NUXT_SESSION_SECRET=

# --- База SQLite в контейнере (том docker-compose: /app/data) ---
NUXT_SQLITE_PATH=/app/data/ote.sqlite

# --- Опционально: ограничение по доменам email ---
# NUXT_ALLOWED_EMAIL_DOMAINS=company.ru

# --- Yandex Cloud (список OTE на главной): ключ SA + каталог по группе в админке ---
# NUXT_YC_SA_KEY_PATH=/app/secrets/yc-sa.json   # смонтируйте файл в compose (см. README)
# либо одной строкой: NUXT_YC_SERVICE_ACCOUNT_JSON=

# --- TeamCity (серверный PAT или логин/пароль) — иначе только токен из профиля пользователя ---
# TeamCity: URL и build type id задаются в админке «Система» по группам; PAT только в профиле пользователя.
